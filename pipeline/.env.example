ANTHROPIC_API_KEY=
# Optional alias if you prefer this name.
# CLAUDE_API_KEY=

# If neither key is set here, the pipeline falls back to the existing Electron
# app config at %APPDATA%\nollywood-ai-pipeline\config.json (`claudeApiKey`).

# Optional: reuse a persistent Chromium profile for logged-in research sources.
# CONTENT_RESEARCH_USER_DATA_DIR=C:\Users\chris\AppData\Local\how-to-content-research-profile

# Optional: set to 1 to skip the manual login pause during test runs.
# CONTENT_RESEARCH_SKIP_LOGIN_PAUSE=1

# Optional: hold the browser open for a fixed login window before scraping.
# Useful when stdin is not interactive. Example: 120000 = 2 minutes.
# CONTENT_RESEARCH_LOGIN_WAIT_MS=120000
